{
  "name": "pharma-backend",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:all": "npm run build",
    "start": "nest start gateway",
    "start:gateway": "nest start gateway",
    "start:identity": "nest start identity-service",
    "start:commerce": "nest start commerce-service",
    "start:operation": "nest start operation-service",
    "start:reporting": "nest start reporting-setting-service",
    "start:notification": "nest start notification-service",
    "start:dev:all": "concurrently -n gateway,identity,commerce,operation,reporting,notification -c blue,green,cyan,magenta,yellow,white \"npm:dev:gateway\" \"npm:dev:identity\" \"npm:dev:commerce\" \"npm:dev:operation\" \"npm:dev:reporting\" \"npm:dev:notification\"",
    "dev:gateway": "nest start gateway --watch",
    "dev:identity": "nest start identity-service --watch",
    "dev:commerce": "nest start commerce-service --watch",
    "dev:operation": "nest start operation-service --watch",
    "dev:reporting": "nest start reporting-setting-service --watch",
    "dev:notification": "nest start notification-service --watch",
    "prisma:generate:identity": "npx prisma generate --schema=prisma/identity/schema.prisma",
    "prisma:generate:commerce": "npx prisma generate --schema=prisma/commerce/schema.prisma",
    "prisma:generate:operation": "npx prisma generate --schema=prisma/operation/schema.prisma",
    "prisma:generate:reporting": "npx prisma generate --schema=prisma/reporting/schema.prisma",
    "prisma:generate:notification": "npx prisma generate --schema=prisma/notification/schema.prisma",
    "prisma:generate:all": "npm run prisma:generate:identity && npm run prisma:generate:commerce && npm run prisma:generate:operation && npm run prisma:generate:reporting && npm run prisma:generate:notification",
    "prisma:migrate:identity": "npx prisma migrate dev --schema=prisma/identity/schema.prisma --name init_identity",
    "prisma:migrate:commerce": "npx prisma migrate dev --schema=prisma/commerce/schema.prisma --name init_commerce",
    "prisma:migrate:operation": "npx prisma migrate dev --schema=prisma/operation/schema.prisma --name init_operation",
    "prisma:migrate:reporting": "npx prisma migrate dev --schema=prisma/reporting/schema.prisma --name init_reporting",
    "prisma:migrate:notification": "npx prisma migrate dev --schema=prisma/notification/schema.prisma --name init_notification",
    "prisma:migrate:all": "npm run prisma:migrate:identity && npm run prisma:migrate:commerce && npm run prisma:migrate:operation && npm run prisma:migrate:reporting && npm run prisma:migrate:notification",
    "prisma:seed:identity": "npx ts-node prisma/identity/seed.ts",
    "prisma:seed:commerce": "npx ts-node prisma/commerce/seed.ts",
    "prisma:seed:operation": "npx ts-node prisma/operation/seed.ts",
    "prisma:seed:reporting": "npx ts-node prisma/reporting/seed.ts",
    "prisma:seed:notification": "npx ts-node prisma/notification/seed.ts",
    "prisma:seed:all": "npm run prisma:seed:identity && npm run prisma:seed:commerce && npm run prisma:seed:operation && npm run prisma:seed:reporting && npm run prisma:seed:notification",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:restart": "docker compose down && docker compose up -d",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:demo": "jest --runInBand --testPathPatterns=demo\\.spec\\.ts",
    "test:smoke": "sh scripts/smoke/demo-smoke.sh",
    "test:e2e": "npm --prefix ../UI-PHARMACY run test:e2e",
    "test:e2e:demo": "npm --prefix ../UI-PHARMACY run test:e2e:demo",
    "test:e2e:ui": "npm --prefix ../UI-PHARMACY run test:e2e:ui",
    "test:rbac:phase8": "node scripts/rbac-phase8-test.js",
    "demo:setup": "npm install",
    "demo:seed": "npm run prisma:seed:all",
    "demo:reset": "npm run prisma:migrate:all && npm run prisma:seed:all",
    "demo:start": "npm run start:dev:all",
    "demo:full:setup": "powershell -ExecutionPolicy Bypass -File scripts/full-demo-setup.ps1",
    "demo:full:setup:test": "powershell -ExecutionPolicy Bypass -File scripts/full-demo-setup.ps1 -RunDemoTests"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/microservices": "^11.1.21",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.21",
    "@prisma/client": "^6.8.2",
    "amqp-connection-manager": "^5.0.0",
    "amqplib": "^2.0.1",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "exceljs": "^4.4.0",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "kafkajs": "^2.2.4",
    "nodemailer": "^8.0.7",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-jwt": "^4.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^6.8.2",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/"
    ]
  }
}
