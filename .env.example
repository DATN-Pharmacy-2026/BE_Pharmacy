NODE_ENV=development

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
PGADMIN_DEFAULT_EMAIL=admin@pharmacy.local
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password

JWT_ACCESS_SECRET=replace_with_min_16_chars_access_secret
JWT_REFRESH_SECRET=replace_with_min_16_chars_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10
PASSWORD_RESET_EXPIRES_MINUTES=30

LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

GATEWAY_PORT=3000
IDENTITY_SERVICE_PORT=3001
COMMERCE_SERVICE_PORT=3002
OPERATION_SERVICE_PORT=3003
REPORTING_SETTING_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
CHATBOT_SERVICE_PORT=3006

FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:4008,http://localhost:3000

IDENTITY_SERVICE_URL=http://localhost:3001
COMMERCE_SERVICE_URL=http://localhost:3002
OPERATION_SERVICE_URL=http://localhost:3003
REPORTING_SETTING_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:3005
CHATBOT_SERVICE_URL=http://localhost:3006

AI_PROVIDER=openai
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=pharmacy_knowledge

IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy_identity?schema=public
COMMERCE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy_commerce?schema=public
OPERATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy_operation?schema=public
INTERNAL_SERVICE_KEY=pharmplus-internal-dev
REPORTING_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy_reporting?schema=public
NOTIFICATION_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pharmacy_notification?schema=public

BROKER_TYPE=rabbitmq
EVENT_BROKER_ENABLED=true
RABBITMQ_URL=amqp://guest:guest@localhost:5672

PAYMENT_GATEWAY_ENABLED=false
PAYMENT_GATEWAY_SANDBOX=true
PAYMENT_PUBLIC_BASE_URL=http://localhost:3000
VNPAY_TMN_CODE=replace_vnpay_tmn_code
VNPAY_HASH_SECRET=replace_vnpay_hash_secret
