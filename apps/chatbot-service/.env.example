CHATBOT_SERVICE_PORT=3006
COMMERCE_SERVICE_URL=http://commerce-service:3002
OPERATION_SERVICE_URL=http://operation-service:3003
REPORTING_SERVICE_URL=http://reporting-setting-service:3004

# Provider: openai or gemini
AI_PROVIDER=openai
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# Gemini API
GEMINI_API_KEY=replace_with_your_gemini_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# OpenAI API (optional fallback)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

VECTOR_DB_PROVIDER=qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=pharmacy_knowledge
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
