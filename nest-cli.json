{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "root": "apps/gateway",
  "sourceRoot": "apps/gateway/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/gateway/tsconfig.app.json"
  },
  "projects": {
    "gateway": {
      "type": "application",
      "root": "apps/gateway",
      "entryFile": "main",
      "sourceRoot": "apps/gateway/src",
      "compilerOptions": {
        "tsConfigPath": "apps/gateway/tsconfig.app.json"
      }
    },
    "identity-service": {
      "type": "application",
      "root": "apps/identity-service",
      "entryFile": "main",
      "sourceRoot": "apps/identity-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/identity-service/tsconfig.app.json"
      }
    },
    "commerce-service": {
      "type": "application",
      "root": "apps/commerce-service",
      "entryFile": "main",
      "sourceRoot": "apps/commerce-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/commerce-service/tsconfig.app.json"
      }
    },
    "operation-service": {
      "type": "application",
      "root": "apps/operation-service",
      "entryFile": "main",
      "sourceRoot": "apps/operation-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/operation-service/tsconfig.app.json"
      }
    },
    "reporting-setting-service": {
      "type": "application",
      "root": "apps/reporting-setting-service",
      "entryFile": "main",
      "sourceRoot": "apps/reporting-setting-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/reporting-setting-service/tsconfig.app.json"
      }
    },
    "notification-service": {
      "type": "application",
      "root": "apps/notification-service",
      "entryFile": "main",
      "sourceRoot": "apps/notification-service/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notification-service/tsconfig.app.json"
      }
    }
  }
}
